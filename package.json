{
  "name": "vite-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\" --fix --quiet",
    "lint:js": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:types": "tsc --noEmit",
    "check:css-vars": "node scripts/check-css-variables.js",
    "check:css-classes": "node scripts/check-css-classes.js",
    "lint": "bun run lint:types && bun run lint:js && bun run lint:css && bun run check:css-vars && bun run check:css-classes",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:debug": "bunx playwright test --debug",
    "test:e2e:report": "bunx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "dependencies": {
    "@blinkdotnew/sdk": "^2.5.0",
    "@blinkdotnew/ui": "0.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@google-analytics/data": "^6.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.21",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.4.16",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "esbuild": "^0.28.0",
    "firebase": "^12.14.0",
    "framer-motion": "^12.38.0",
    "glob": "^13.0.6",
    "hono": "^4.12.23",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "postcss": "8.4.31",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-responsive": "^10.0.1",
    "recharts": "^3.8.1",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "3.3.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  }
}
